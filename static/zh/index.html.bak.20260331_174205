    <section class="container" id="contact" style="background: #f8f9fa; border-radius: 10px;">
        <h2 class="section-title">联系我们</h2>
        <div style="max-width: 600px; margin: 0 auto;">
            <form id="contactForm" action="https://formspree.io/f/xwvnzkol" method="POST" style="display: flex; flex-direction: column; gap: 20px;">
                <input type="text" name="name" id="name" placeholder="您的姓名" required style="padding: 15px; border: 1px solid #ddd; border-radius: 5px; font-size: 16px;">
                <input type="email" name="email" id="email" placeholder="您的邮箱" required style="padding: 15px; border: 1px solid #ddd; border-radius: 5px; font-size: 16px;">
                <textarea name="message" id="message" placeholder="您的留言" rows="5" required style="padding: 15px; border: 1px solid #ddd; border-radius: 5px; font-size: 16px; resize: vertical;"></textarea>
                <input type="hidden" name="ip_address" id="ip_address">
                <input type="hidden" name="user_agent" id="user_agent">
                <input type="hidden" name="timestamp" id="timestamp">
                <button type="submit" id="submitBtn" style="padding: 15px 40px; background: #006994; color: white; border: none; border-radius: 5px; font-size: 16px; font-weight: bold; cursor: pointer;">
                    发送留言
                </button>
            </form>
            <p id="statusMsg" style="text-align: center; margin-top: 15px; font-size: 14px; color: #666;">
                留言将直接发送到 imperialdiving2015@gmail.com
            </p>
            <script>
                // 防flood保护
                const FORMSPREE_FORM_ID = 'xwvnzkol';
                const SUBMIT_COOLDOWN = 60000; // 60秒冷却时间
                const MAX_SUBMITS_PER_HOUR = 5; // 每小时最多5次
                
                document.addEventListener('DOMContentLoaded', function() {
                    const form = document.getElementById('contactForm');
                    const submitBtn = document.getElementById('submitBtn');
                    const statusMsg = document.getElementById('statusMsg');
                    
                    // 获取客户端信息
                    fetch('https://api.ipify.org?format=json')
                        .then(response => response.json())
                        .then(data => {
                            document.getElementById('ip_address').value = data.ip;
                        })
                        .catch(() => {
                            document.getElementById('ip_address').value = 'Unknown';
                        });
                    
                    document.getElementById('user_agent').value = navigator.userAgent;
                    document.getElementById('timestamp').value = new Date().toISOString();
                    
                    // 检查提交频率
                    function checkSubmitRate() {
                        const lastSubmit = localStorage.getItem('lastSubmitTime');
                        const submitCount = parseInt(localStorage.getItem('submitCount') || '0');
                        const countTimestamp = parseInt(localStorage.getItem('countTimestamp') || '0');
                        const now = Date.now();
                        
                        // 检查冷却时间
                        if (lastSubmit && (now - parseInt(lastSubmit)) < SUBMIT_COOLDOWN) {
                            const remainingTime = Math.ceil((SUBMIT_COOLDOWN - (now - parseInt(lastSubmit))) / 1000);
                            return {
                                allowed: false,
                                message: `请等待 ${remainingTime} 秒后再试`
                            };
                        }
                        
                        // 检查每小时提交次数
                        if (countTimestamp && (now - countTimestamp) < 3600000 && submitCount >= MAX_SUBMITS_PER_HOUR) {
                            const remainingTime = Math.ceil((3600000 - (now - countTimestamp)) / 60000);
                            return {
                                allowed: false,
                                message: `您已达到每小时最大提交次数，请 ${remainingTime} 分钟后再试`
                            };
                        }
                        
                        return { allowed: true };
                    }
                    
                    // 更新提交计数
                    function updateSubmitCount() {
                        const now = Date.now();
                        const countTimestamp = parseInt(localStorage.getItem('countTimestamp') || '0');
                        let submitCount = parseInt(localStorage.getItem('submitCount') || '0');
                        
                        // 如果超过1小时，重置计数
                        if (!countTimestamp || (now - countTimestamp) >= 3600000) {
                            localStorage.setItem('countTimestamp', now.toString());
                            submitCount = 0;
                        }
                        
                        localStorage.setItem('submitCount', (submitCount + 1).toString());
                        localStorage.setItem('lastSubmitTime', now.toString());
                    }
                    
                    // 表单提交处理
                    form.addEventListener('submit', function(e) {
                        e.preventDefault();
                        
                        // 更新时间戳
                        document.getElementById('timestamp').value = new Date().toISOString();
                        
                        // 检查提交频率
                        const check = checkSubmitRate();
                        if (!check.allowed) {
                            statusMsg.textContent = check.message;
                            statusMsg.style.color = '#dc3545';
                            return;
                        }
                        
                        // 禁用提交按钮
                        submitBtn.disabled = true;
                        submitBtn.textContent = '发送中...';
                        statusMsg.textContent = '正在发送留言...';
                        statusMsg.style.color = '#666';
                        
                        // 提交表单
                        fetch(form.action, {
                            method: 'POST',
                            body: new FormData(form),
                            headers: {
                                'Accept': 'application/json'
                            }
                        })
                        .then(response => {
                            if (response.ok) {
                                statusMsg.textContent = '留言发送成功！我们会尽快回复您。';
                                statusMsg.style.color = '#28a745';
                                form.reset();
                                updateSubmitCount();
                            } else {
                                statusMsg.textContent = '发送失败，请稍后重试。';
                                statusMsg.style.color = '#dc3545';
                            }
                        })
                        .catch(error => {
                            statusMsg.textContent = '发送失败，请稍后重试。';
                            statusMsg.style.color = '#dc3545';
                        })
                        .finally(() => {
                            submitBtn.disabled = false;
                            submitBtn.textContent = '发送留言';
                        });
                    });
                });
            </script>
