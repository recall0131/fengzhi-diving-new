<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>奉旨潜水 | Imperial Diving</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0B3D4A;
      --bg-deep: #061F28;
      --text: #F0F4F5;
      --text-muted: #7A9BA3;
      --accent: #4ECDC4;
      --accent-dim: rgba(78, 205, 196, 0.12);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Noto Sans SC', 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ===== NAV ===== */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.75rem 4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: all 0.5s ease;
    }

    .nav.scrolled {
      background: rgba(6, 31, 40, 0.85);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      padding: 1.25rem 4rem;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      color: var(--text);
    }

    .nav-logo svg {
      width: 28px;
      height: 28px;
      opacity: 0.85;
    }

    .nav-logo span {
      font-family: 'Noto Sans SC', sans-serif;
      font-weight: 500;
      font-size: 1.05rem;
      letter-spacing: 0.02em;
    }

    .nav-links {
      display: flex;
      gap: 3.5rem;
      list-style: none;
    }

    .nav-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 400;
      letter-spacing: 0.03em;
      transition: color 0.3s;
    }

    .nav-links a:hover { color: var(--accent); }

    /* ===== HERO ===== */
    .hero {
      min-height: 100vh;
      display: grid;
      place-items: center;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 30%, rgba(78, 205, 196, 0.07) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 70%, rgba(78, 205, 196, 0.04) 0%, transparent 50%);
    }

    .hero-texture {
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: 0.025;
    }

    .hero-inner {
      position: relative;
      z-index: 10;
      text-align: center;
      max-width: 760px;
      padding: 2rem;
    }

    .hero-mask {
      width: 72px;
      height: 72px;
      margin: 0 auto 3rem;
      opacity: 0.65;
    }

    .hero-eyebrow {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.75rem;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.8s ease 0.1s forwards;
    }

    .hero-title {
      font-family: 'Noto Sans SC', sans-serif;
      font-size: clamp(2.8rem, 7vw, 4.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 1.75rem;
      opacity: 0;
      transform: translateY(24px);
      animation: fadeUp 0.9s ease 0.25s forwards;
    }

    .hero-title em {
      font-style: normal;
      color: var(--accent);
    }

    .hero-desc {
      font-size: 1.05rem;
      font-weight: 300;
      color: var(--text-muted);
      max-width: 480px;
      margin: 0 auto 3.5rem;
      line-height: 1.9;
      opacity: 0;
      transform: translateY(20px);
      animation: fadeUp 0.8s ease 0.4s forwards;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--accent);
      color: var(--bg-deep);
      padding: 1rem 2.25rem;
      border-radius: 100px;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: all 0.35s ease;
      opacity: 0;
      transform: translateY(16px);
      animation: fadeUp 0.8s ease 0.55s forwards;
    }

    .hero-cta:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(78, 205, 196, 0.28);
    }

    .hero-cta svg {
      width: 16px;
      height: 16px;
      transition: transform 0.3s;
    }

    .hero-cta:hover svg {
      transform: translateX(3px);
    }

    /* ===== STATS BAR ===== */
    .stats-bar {
      background: var(--bg-deep);
      padding: 4.5rem 4rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background-clip: padding-box;
    }

    .stat-item {
      text-align: center;
      padding: 1.5rem;
      position: relative;
    }

    .stat-item + .stat-item::before {
      content: '';
      position: absolute;
      left: 0;
      top: 20%;
      height: 60%;
      width: 1px;
      background: rgba(255,255,255,0.06);
    }

    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 3.25rem;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 0.4rem;
    }

    .stat-label {
      font-size: 0.82rem;
      color: var(--text-muted);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 400;
    }

    /* ===== SAFETY ===== */
    .safety {
      padding: 9rem 4rem;
      text-align: center;
    }

    .safety-inner {
      max-width: 560px;
      margin: 0 auto;
    }

    .safety-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--accent-dim);
      border: 1px solid rgba(78, 205, 196, 0.25);
      padding: 0.45rem 1.2rem;
      border-radius: 100px;
      font-size: 0.78rem;
      color: var(--accent);
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 2rem;
    }

    .safety-badge svg {
      width: 14px;
      height: 14px;
    }

    .safety-title {
      font-family: 'Noto Sans SC', sans-serif;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin-bottom: 1.5rem;
    }

    .safety-text {
      font-size: 1rem;
      color: var(--text-muted);
      font-weight: 300;
      line-height: 1.9;
    }

    /* ===== COURSES ===== */
    .courses-section {
      padding: 6rem 4rem 9rem;
      background: var(--bg-deep);
    }

    .courses-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-eyebrow {
      text-align: center;
      font-size: 0.75rem;
      color: var(--accent);
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }

    .section-title {
      text-align: center;
      font-family: 'Noto Sans SC', sans-serif;
      font-size: clamp(1.6rem, 3.5vw, 2.1rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 3.5rem;
    }

    .courses-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .course-card {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(255,255,255,0.055);
      border-radius: 20px;
      padding: 2.25rem 2rem;
      transition: all 0.4s ease;
      cursor: pointer;
    }

    .course-card:hover {
      background: rgba(255,255,255,0.045);
      border-color: rgba(78, 205, 196, 0.25);
      transform: translateY(-5px);
    }

    .course-tag {
      display: inline-block;
      background: var(--accent-dim);
      color: var(--accent);
      padding: 0.28rem 0.85rem;
      border-radius: 100px;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      margin-bottom: 1.2rem;
    }

    .course-name {
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 0.8rem;
      line-height: 1.3;
    }

    .course-desc {
      color: var(--text-muted);
      font-size: 0.9rem;
      line-height: 1.75;
      font-weight: 300;
      margin-bottom: 1.75rem;
    }

    .course-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .course-meta {
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    .course-price {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--accent);
    }

    /* ===== CTA ===== */
    .cta-section {
      padding: 10rem 4rem;
      text-align: center;
      position: relative;
    }

    .cta-section::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(78,205,196,0.09) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-title {
      font-family: 'Noto Sans SC', sans-serif;
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 1.25rem;
      position: relative;
    }

    .cta-sub {
      color: var(--text-muted);
      font-size: 1.05rem;
      font-weight: 300;
      margin-bottom: 3rem;
    }

    /* ===== FOOTER ===== */
    footer {
      background: var(--bg-deep);
      padding: 3.5rem 4rem 2.5rem;
      border-top: 1px solid rgba(255,255,255,0.045);
    }

    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-brand {
      font-size: 1rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .footer-brand svg {
      width: 22px;
      height: 22px;
      opacity: 0.7;
    }

    .footer-links {
      display: flex;
      gap: 2.5rem;
      list-style: none;
    }

    .footer-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.88rem;
      transition: color 0.3s;
    }

    .footer-links a:hover { color: var(--accent); }

    .footer-copy {
      text-align: center;
      padding-top: 2rem;
      margin-top: 2rem;
      border-top: 1px solid rgba(255,255,255,0.04);
      color: var(--text-muted);
      font-size: 0.82rem;
    }

    /* ===== ANIMATIONS ===== */
    @keyframes fadeUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: all 0.85s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 900px) {
      .nav { padding: 1.5rem 2rem; }
      .nav.scrolled { padding: 1rem 2rem; }
      .nav-links { display: none; }
      .stats-bar { grid-template-columns: 1fr; padding: 3rem 2rem; }
      .stat-item + .stat-item::before { display: none; }
      .courses-grid { grid-template-columns: 1fr; }
      .courses-section, .safety, .cta-section { padding-left: 2rem; padding-right: 2rem; }
      .footer-inner { flex-direction: column; gap: 2rem; text-align: center; }
      .footer-links { flex-wrap: wrap; justify-content: center; }
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav class="nav" id="navbar">
    <a href="#" class="nav-logo">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
        <ellipse cx="12" cy="7" rx="5" ry="3.5"/>
        <path d="M7 7L5 4M17 7l2-3"/>
        <path d="M12 10.5v6"/>
        <path d="M8 22c0-2 1.5-3.5 4-3.5s4 1.5 4 3.5"/>
      </svg>
      <span>奉旨潜水</span>
    </a>
    <ul class="nav-links">
      <li><a href="#courses">课程</a></li>
      <li><a href="#safety">安全</a></li>
      <li><a href="#about">关于</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-texture"></div>
    <div class="hero-inner">
      <svg class="hero-mask" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <ellipse cx="12" cy="7" rx="5" ry="3.5"/>
        <path d="M7 7L5 4M17 7l2-3"/>
        <path d="M12 10.5v6"/>
        <path d="M8 22c0-2 1.5-3.5 4-3.5s4 1.5 4 3.5"/>
      </svg>
      <p class="hero-eyebrow">PADI 认证潜水中心</p>
      <h1 class="hero-title">探索深海<br><em>从奉旨开始</em></h1>
      <p class="hero-desc">专业潜水培训 · 全球顶级目的地 · 安全第一</p>
      <a href="#courses" class="hero-cta">
        查看课程
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats-bar">
    <div class="stat-item reveal">
      <div class="stat-num">1000+</div>
      <div class="stat-label">学员人数</div>
    </div>
    <div class="stat-item reveal">
      <div class="stat-num">50+</div>
      <div class="stat-label">教练团队</div>
    </div>
    <div class="stat-item reveal">
      <div class="stat-num">6年</div>
      <div class="stat-label">服务经验</div>
    </div>
  </section>

  <!-- SAFETY -->
  <section class="safety" id="safety">
    <div class="safety-inner reveal">
      <div class="safety-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        安全第一
      </div>
      <h2 class="safety-title">你的安全是我们的<br>首要责任</h2>
      <p class="safety-text">每一位教练都经过严格认证，每一项课程都遵循国际标准。我们坚持小班教学，确保每位学员都能得到充分的指导和练习时间。</p>
    </div>
  </section>

  <!-- COURSES -->
  <section class="courses-section" id="courses">
    <div class="courses-inner">
      <p class="section-eyebrow reveal">热门课程</p>
      <h2 class="section-title reveal">开启你的潜水之旅</h2>
      <div class="courses-grid">
        <div class="course-card reveal">
          <span class="course-tag">零基础</span>
          <h3 class="course-name">OW 开放水域潜水员</h3>
          <p class="course-desc">入门课程，学习基础潜水技能，获得全球认可的 PADI 证书。最大深度 18 米。</p>
          <div class="course-foot">
            <span class="course-meta">4天 · 理论+实践</span>
            <span class="course-price">¥2,800</span>
          </div>
        </div>
        <div class="course-card reveal">
          <span class="course-tag">进阶</span>
          <h3 class="course-name">AOW 进阶开放水域</h3>
          <p class="course-desc">提升潜水技能，尝试夜潜、深潜、沉船潜等精彩项目。最大深度 30 米。</p>
          <div class="course-foot">
            <span class="course-meta">3天 · 5次开放水域</span>
            <span class="course-price">¥2,200</span>
          </div>
        </div>
        <div class="course-card reveal">
          <span class="course-tag">高级</span>
          <h3 class="course-name">Rescue 救援潜水员</h3>
          <p class="course-desc">学习紧急救援技能，提升安全意识和自救互救能力。</p>
          <div class="course-foot">
            <span class="course-meta">5天 · 理论+实践</span>
            <span class="course-price">¥1,800</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="reveal">
      <h2 class="cta-title">准备好潜入深海了吗？</h2>
      <p class="cta-sub">立即咨询，开启你的潜水之旅</p>
      <a href="#" class="hero-cta">立即报名</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer id="about">
    <div class="footer-inner">
      <div class="footer-brand">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
          <ellipse cx="12" cy="7" rx="5" ry="3.5"/>
          <path d="M12 10.5v6"/>
          <path d="M8 22c0-2 1.5-3.5 4-3.5s4 1.5 4 3.5"/>
        </svg>
        奉旨潜水
      </div>
      <ul class="footer-links">
        <li><a href="#">课程</a></li>
        <li><a href="#">目的地</a></li>
        <li><a href="#">关于</a></li>
        <li><a href="#">联系</a></li>
      </ul>
    </div>
    <div class="footer-copy">
      © 2024 奉旨潜水 Imperial Diving · PADI国际认证潜水中心
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          const delay = Array.from(entries).indexOf(entry) * 80;
          setTimeout(() => entry.target.classList.add('visible'), delay);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 60);
    });
  </script>
</body>
</html>
